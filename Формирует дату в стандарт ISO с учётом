//Сервер ожидает от нас стандарт 2026-03-12Т00:00:00. Логика такая, мы ищем свободные слоты врача +30 минут с момента обращения клеинта. Чтобы клиент успел доехать до клиники
//Делаем запрос на сервер, который даёт точное время и погнали

function pad(n) {
              return n < 10 ? '0' + n : n;
            }
            // Получаем компоненты времени
            var components = [
              $session.httpResponse.year,
              $session.httpResponse.month - 1, // месяцы нумеруются с нуля
              $session.httpResponse.day,
              $session.httpResponse.hour,
              $session.httpResponse.minute
            ];
            // Создаем объект Date, представляющий московское время
            var dateObj = new Date(Date.UTC.apply(null, components));
            // Добавляем ровно 30 минут
            dateObj.setMinutes(dateObj.getMinutes() + 30);
            // Извлекаем новые значения компонентов (учитывая возможные переходы часа/дня)
            var newY = dateObj.getUTCFullYear(),
                newM = dateObj.getUTCMonth() + 1, // обратно добавляем единицу месяца
                newD = dateObj.getUTCDate(),
                newH = dateObj.getUTCHours(),
                newMin = dateObj.getUTCMinutes(),
                newSec = dateObj.getUTCSeconds(); // секунды изначально были нулевыми
            // Формируем строки начала и конца интервала
                $session.dt_start = newY + '-' + pad(newM) + '-' + pad(newD) +
                           'T' + pad(newH) + ':' + pad(newMin) + ':' + pad(newSec);
            // Создаем дату для конца интервала (текущая дата + 90 дней)
            var endDate = new Date($session.httpResponse.formatted + 'T00:00:00');
            endDate.setDate(endDate.getDate() + 45);
            // Форматируем дату конца интервала
            var endY = endDate.getUTCFullYear(),
                endM = endDate.getUTCMonth() + 1,
                endD = endDate.getUTCDate();
            $session.dt_end = endY + '-' + pad(endM) + '-' + pad(endD) + 'T23:59:59';
