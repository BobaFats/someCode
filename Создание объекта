//Делаем новый объект под свои задача. Основной объект слишком большой и не всё нам требуется.
$session.clinics = [];
            $session.httpResponse = 0;
            $session.doc_list = [];
            for(var a = 0; a < $session.dataThing.length; a++){
                for(var b = 0; b < $session.dataThing[a].specs.length; b++){
                        // Используем регулярное выражение для выбора любых чисел
                        var ageRange = $session.dataThing[a].specs[b].clinics[0].age_range;
                        var numbers = ageRange.match(/\d+/g);
                        // Обрабатываем возможные варианты
                        if (numbers.length === 1 && $session.age_client === parseInt(numbers[0], 10)) {
                            $session.doc_list.push({doc_id:$session.dataThing[a].id, doc_name: $session.dataThing[a].name, spec_id: $session.spec_id, spec_name:$session.spec_name, countDaysByDoctor:$session.dataThing[a].countDaysByDoctor, clinics: $session.dataThing[a].clinics});
                        } else if (numbers.length === 2) {
                        // Диапазон возрастов
                        var lowerBound = parseInt(numbers[0], 10);
                        var upperBound = parseInt(numbers[1], 10);
                        if($session.age_client >= lowerBound && $session.age_client <= upperBound){
                            $session.doc_list.push({doc_id:$session.dataThing[a].id, doc_name: $session.dataThing[a].name, spec_id: $session.spec_id, spec_name:$session.spec_name, countDaysByDoctor:$session.dataThing[a].countDaysByDoctor, clinics: $session.dataThing[a].clinics});
                        }
                        }
                    }
                }
            if($session.doc_list.length === 0){
                $session.flag = 0;
            } else {
                $session.flag = 1;
            }
            $session.dataThing = 0;
            for(var a = 0; a < $session.doc_list.length; a++){
                for(var b = 0; b < $session.doc_list[a].clinics.length; b++)
                    var item = $session.doc_list[a].clinics[b];
                    if ($session.clinics.indexOf(item) === -1){
                        $session.clinics.push(item);
                    }
            }
