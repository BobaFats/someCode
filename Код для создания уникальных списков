//Для предоставления клиенту списка данных, в базе, которые, могут повторяться. Но нам нужно показывать клиенту только уникальные значения. В данном конкретном случае
//у нас есть большое количестве врачей и ограниченное количество адресов клиник, где они принимают.
$session.httpResponse = 0;
$session.clinics_back = [];

//Запускаем перебор данных
for(var a = 0; a < $session.dataThing.result.length; a++){
    for(var b = 0; b < $session.clinics.length; b++){
        //Ищем значения
        if($session.clinics[b] === $session.dataThing.result[a].id){
            var item = $session.dataThing.result[a].address;
                //Следующая строчка разбивает строку до первой зпятой и убирает лишние пробелы по краям. Остаются только город и улица.  
                item = item.split(',')[0].trim();
                //ищем найденное значение в нашем массиве. Такого значения в массиве не находится, то indexOf возвращает нам -1. Соответственно, записываем значение в массив
                if ($session.clinics_back.indexOf(item) === -1){
                    $session.clinics_back.push(item);
                   }
               }
        }
   }
